{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "OSA Midnight Oil",
  "version": "0.1.0",
  "identifier": "com.osa.midnightoil",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://localhost:5173",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "OSA Midnight Oil",
        "center": true,
        "width": 1728,
        "height": 1117,
        "minWidth": 1360,
        "minHeight": 860,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "../public/favicon.png"
    ]
  }
}
