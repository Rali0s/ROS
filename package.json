{
  "name": "osa-midnight-oil",
  "private": true,
  "version": "1.2.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "npm run build:wasm || echo 'WASM build skipped' && vite build",
    "build:wasm": "cd rust-core && wasm-pack build --target web --out-dir pkg",
    "desktop:dev": "cd src-tauri && cargo tauri dev",
    "desktop:build": "cd src-tauri && cargo tauri build",
    "lint": "eslint .",
    "preview": "vite preview",
    "release:checksums": "node scripts/generate-release-checksums.mjs",
    "site:beta:serve": "python3 -m http.server 4178 --directory beta-site"
  },
  "dependencies": {
    "@tauri-apps/api": "^2.10.1",
    "env": "^0.0.2",
    "jszip": "^3.10.1",
    "lucide-react": "^0.263.1",
    "nostr-tools": "^2.7.2",
    "react": "^18.2.0",
    "react-dom": "^18.2.0"
  },
  "devDependencies": {
    "@types/react": "^18.2.15",
    "@types/react-dom": "^18.2.7",
    "@vitejs/plugin-react": "^4.0.3",
    "autoprefixer": "^10.4.14",
    "eslint": "^8.45.0",
    "eslint-plugin-react": "^7.32.2",
    "eslint-plugin-react-hooks": "^4.6.0",
    "eslint-plugin-react-refresh": "^0.4.3",
    "globals": "^15.9.0",
    "postcss": "^8.4.27",
    "tailwindcss": "^3.3.3",
    "vite": "^4.4.5"
  }
}
